{
  "name": "sillytavern-char_cardplus",
  "author": "awaae001",
  "description": "快速卡片格式化工具",
  "private": true,
  "version": "0.1.17",
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "dev:web": "vite",
    "prepare:icons": "tauri icon src-tauri/icons/icon.png -o src-tauri/icons",
    "prebuild:desktop": "pnpm prepare:icons",
    "type-check": "vue-tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json",
    "build": "vite build",
    "preview": "vite preview",
    "start": "tauri dev",
    "build:desktop": "tauri build",
    "format": "prettier --write \"src/**/*.{vue,ts,tsx,js,jsx,json,css,scss,md}\" \"scripts/**/*.{mjs,js,ts}\"",
    "format:check": "prettier --check \"src/**/*.{vue,ts,tsx,js,jsx,json,css,scss,md}\" \"scripts/**/*.{mjs,js,ts}\""
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/state": "^6.5.4",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.39.16",
    "@element-plus/icons-vue": "^2.3.2",
    "@octokit/rest": "^22.0.1",
    "@tailwindcss/vite": "^4.2.1",
    "@tauri-apps/api": "^2.10.1",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.2",
    "@vueuse/core": "^14.2.1",
    "codemirror": "^6.0.2",
    "crc": "^4.3.2",
    "dexie": "^4.3.0",
    "ejs": "^4.0.1",
    "element-plus": "^2.13.5",
    "exifreader": "^4.36.2",
    "js-base64": "^3.7.8",
    "js-yaml": "^4.1.1",
    "opencc-js": "^1.0.5",
    "pinia": "^3.0.4",
    "png-chunk-text": "^1.0.0",
    "png-chunks-extract": "^1.0.0",
    "splitpanes": "^4.0.4",
    "tailwindcss": "^4.2.1",
    "uuid": "13.0.0",
    "vue": "^3.5.29",
    "vue-router": "^5.0.3",
    "vuedraggable": "^4.1.0",
    "webdav": "^5.9.0"
  },
  "devDependencies": {
    "@iconify/vue": "5.0.0",
    "@tauri-apps/cli": "^2.10.1",
    "@types/ejs": "^3.1.5",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.3.5",
    "@types/opencc-js": "^1.0.3",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/tsconfig": "^0.8.1",
    "concurrently": "^9.2.1",
    "prettier": "^3.8.1",
    "terser": "^5.46.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vue-tsc": "^3.2.5",
    "wait-on": "^9.0.4"
  },
  "pnpm": {
    "overrides": {
      "minimatch@>=9.0.0 <9.0.6": "9.0.6"
    },
    "ignoredBuiltDependencies": [
      "esbuild"
    ],
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "exifreader",
      "vue-demi"
    ]
  }
}
