{
  "productName": "sillytavern-char_cardplus",
  "version": "0.1.20",
  "identifier": "com.awaae001.cardplus",
  "build": {
    "beforeDevCommand": "pnpm dev:web",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:3066",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "St_cardplus",
        "width": 1620,
        "height": 780,
        "resizable": true,
        "zoomHotkeysEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  }
}
